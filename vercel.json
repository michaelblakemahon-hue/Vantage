{
    "version": 2,
    "functions": {
          "api/auth.js":    { "maxDuration": 30 },
          "api/clients.js": { "maxDuration": 30 },
          "api/extract.js": { "maxDuration": 60 }
    },
    "routes": [
          { "src": "/api/auth",    "dest": "/api/auth.js" },
          { "src": "/api/clients", "dest": "/api/clients.js" },
          { "src": "/api/extract", "dest": "/api/extract.js" },
          { "src": "/(.*)",        "dest": "/public/$1" }
    ]
}
